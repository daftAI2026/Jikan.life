{
  "name": "jikan-life",
  "version": "1.9.13",
  "description": "Jikan.life - Dynamic wallpaper generator",
  "main": "worker/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "node --test tests/*.test.js",
    "build": "vite build",
    "preview": "vite preview",
    "sync:version-metadata": "node scripts/sync-version-metadata.js",
    "sync:wallpaper-snapshots": "node scripts/sync-wallpaper-snapshots.js",
    "check:version-metadata": "node scripts/sync-version-metadata.js --check",
    "hooks:install": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath scripts/git-hooks || true",
    "postinstall": "npm run hooks:install",
    "version": "npm run sync:version-metadata",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@cloudflare/kumo": "^1.15.0",
    "@phosphor-icons/react": "^2.1.10",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daftAI2026/Jikan.life.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/daftAI2026/Jikan.life/issues"
  },
  "homepage": "https://github.com/daftAI2026/Jikan.life#readme"
}
